---
import "./color-picker.css";

interface Props {
    id: string;
    layout?: "horizontal" | "vertical";
    displayLabel?: "show" | "hide";
    size?: "normal" | "big";

    //CMS
    groupAriaLabel?: string;
    carmineRedLabel?: string;
    trafficPurpleLabel?: string;
    pearlLightGreyLabel?: string;
    pureGreenLabel?: string;
    brightRedOrangeLabel?: string;
    pearlWhiteLabel?: string;
    skyBlueLabel?: string;
    zincYellowLabel?: string;
    sandYellowLabel?: string;
    jetBlackLabel?: string;
}
const {
    id,
    layout = "vertical",
    displayLabel = true,
    size = "normal",

    //CMS
    groupAriaLabel = "Select a color",
    carmineRedLabel = "carmine red",
    trafficPurpleLabel = "traffic purple",
    pearlLightGreyLabel = "pearl light grey",
    pureGreenLabel = "pure green",
    brightRedOrangeLabel = "bright red orange",
    pearlWhiteLabel = "pearl white",
    skyBlueLabel = "sky blue",
    zincYellowLabel = "zinc yellow",
    sandYellowLabel = "sand yellow",
    jetBlackLabel = "jet black",
} = Astro.props;
---

<!-- NOTE - the initialization of the click functionalities of this color picker is made inside color-picker.ts -->
<div
    class:list={["color-picker-wrapper", layout, displayLabel, size]}
    id={id}
    role="radiogroup"
    aria-label={groupAriaLabel}
>
    <!-- BRIGHT RED ORANGE -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--bright-red-orange"
        role="radio"
        aria-checked="false"
        aria-label={brightRedOrangeLabel}
    >
        <strong>{brightRedOrangeLabel}</strong>
        <div class="color bright-red-orange" aria-hidden="true"></div>
    </button>

    <!-- CARMINE RED -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--carmine-red"
        role="radio"
        aria-checked="false"
        aria-label={carmineRedLabel}
    >
        <strong>{carmineRedLabel}</strong>
        <div class="color carmine-red" aria-hidden="true"></div>
    </button>

    <!-- TRAFFIC PURPLE -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--traffic-purple"
        role="radio"
        aria-checked="false"
        aria-label={trafficPurpleLabel}
    >
        <strong>{trafficPurpleLabel}</strong>
        <div class="color traffic-purple" aria-hidden="true"></div>
    </button>

    <!-- PEARL LIGHT GREY -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--pearl-light-grey"
        role="radio"
        aria-checked="false"
        aria-label={pearlLightGreyLabel}
    >
        <strong>{pearlLightGreyLabel}</strong>
        <div class="color pearl-light-grey" aria-hidden="true"></div>
    </button>

    <!-- PURE GREEN -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--pure-green"
        role="radio"
        aria-checked="false"
        aria-label={pureGreenLabel}
    >
        <strong>{pureGreenLabel}</strong>
        <div class="color pure-green" aria-hidden="true"></div>
    </button>

    <!-- PEARL WHITE -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--pearl-white"
        role="radio"
        aria-checked="false"
        aria-label={pearlWhiteLabel}
    >
        <strong>{pearlWhiteLabel}</strong>
        <div class="color pearl-white" aria-hidden="true"></div>
    </button>

    <!-- SKY BLUE -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--sky-blue"
        role="radio"
        aria-checked="false"
        aria-label={skyBlueLabel}
    >
        <strong>{skyBlueLabel}</strong>
        <div class="color sky-blue" aria-hidden="true"></div>
    </button>

    <!-- ZINC YELLOW -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--zinc-yellow"
        role="radio"
        aria-checked="false"
        aria-label={zincYellowLabel}
    >
        <strong>{zincYellowLabel}</strong>
        <div class="color zinc-yellow" aria-hidden="true"></div>
    </button>

    <!-- SAND YELLOW -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--sand-yellow"
        role="radio"
        aria-checked="false"
        aria-label={sandYellowLabel}
    >
        <strong>{sandYellowLabel}</strong>
        <div class="color sand-yellow" aria-hidden="true"></div>
    </button>

    <!-- JET BLACK -->
    <button
        type="button"
        class="color-label"
        data-color-css-var-key="--jet-black"
        role="radio"
        aria-checked="false"
        aria-label={jetBlackLabel}
    >
        <strong>{jetBlackLabel}</strong>
        <div class="color jet-black" aria-hidden="true"></div>
    </button>
</div>
