---
import { sanityClient } from "sanity:client";
import AboutUsContent from "../../content/AboutUsContent.astro";
import PageContainer from "../../layout/PageContainer.astro";
import type { AboutUs, SiteNavigators, } from "../../../studio-lorika-ontop/sanity.types";

const SITE_NAVIGATORS_QUERY = `
    *[_type == "siteNavigators" && lang == "en"]`;
const siteNavigators = await sanityClient.fetch<SiteNavigators[]>(
    SITE_NAVIGATORS_QUERY,
);

const ABOUT_US_QUERY = `
  *[_type == "aboutUs" && lang == "en"]{
    ...,
    "heroVideoDesktopUrl": heroVideoDesktop.asset->url,
    "heroVideoMobileUrl": heroVideoMobile.asset->url
  }
`;
const aboutUs = await sanityClient.fetch<AboutUs[]>(ABOUT_US_QUERY);
---

<PageContainer
    title="Ontop by Lorika"
    description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    canonical="https://www.example.com/lorem-ipsum"
    robots="index, follow"
    ogImage="https://www.example.com/images/lorem-ipsum.jpg"
    ogLocale="en_US"
    ogSiteName="Lorem Ipsum Site"
    twitterCard="summary_large_image"
    twitterSite="@loremipsum"
    twitterCreator="@creatorlorem"
    siteNavigators={siteNavigators[0]}
>
    <AboutUsContent AboutUsData={aboutUs[0]}></AboutUsContent>
</PageContainer>
